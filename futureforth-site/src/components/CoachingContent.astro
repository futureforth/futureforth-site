---
// Shared body content for /dave-delaney-coaching and /personal-coaching.
// Squarespace treats these as the same page (personal-coaching 301s to
// dave-delaney-coaching); we keep both URLs live per the SEO brief, sharing
// this partial so the real copy only needs to be maintained in one place.
import Testimonial from './Testimonial.astro';

const testimonials = [
  { quote: "I can directly attribute at least 70% of sales at my company to ideas and programs that Dave came up with or helped me manage.", name: 'Phil Shmerling', role: 'SVP, Relationship Manager at Studio Bank' },
  { quote: "I'll keep this short and to the point - spending time with Dave to glean his insights, perspective, and experience...is priceless. Dave is at the top of my list as a resource and advisor.", name: 'Christopher Parks', role: 'Founder, CDO, SVP Business Development, Change Healthcare' },
  { quote: "We cannot recommend him enough for anyone who is confused or overwhelmed on how to market your product or service digitally in a climate that seems to change daily.", name: 'Suzanne C. Bowen', role: 'Founder and Creator of BarreAmped' },
  { quote: 'He is extremely knowledgeable about all aspects of digital media. He comes up with great ideas and knows how to implement them.', name: 'Jean Spivey', role: "Old Settler's Music Festival" },
  { quote: 'His advice was invaluable as he stretched me to think outside my comfort zone.', name: 'Jim Cumbee', role: 'JD, MBA' },
  { quote: 'The results so far, double digit increase in traffic across all our social media platforms and website.', name: 'Meryl Taylor', role: 'Chief Marketing Officer at Mark Zinder & Associates' },
];
---
<section class="hero">
  <div class="container">
    <p class="eyebrow" style="color: var(--color-accent);">1:1 &amp; Team Coaching</p>
    <h1>Excel in your business and career with Strategic Communication Coach, Dave Delaney.</h1>
    <p class="lede" style="color:#dbe3ee;">Improve your clarity, confidence, and communication at work and in life.</p>
    <div class="hero__actions">
      <a href="/contact" class="btn btn-primary">Book a Complimentary 1:1 Discovery Call</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="hero__grid hero__grid--split">
      <div>
        <h3>Trusted by leaders at Google, LinkedIn, FedEx, UPS, and hundreds of growing organizations.</h3>
        <p>
          Communication shapes every opportunity in your career, from your relationships, your
          leadership, your impact, and the way people experience you.
        </p>
        <p>
          I help professionals gain clarity, confidence, and direction so they can communicate better,
          follow through consistently, reduce overwhelm, and build work and lives that feel aligned.
        </p>
        <p>
          My coaching integrates an <strong>ADHD-aware approach</strong> for clients who deal with
          distraction, overthinking, or high-intensity ideas &mdash; giving every type of thinker the
          tools to make meaningful progress.
        </p>
      </div>
      <div>
        <img src="/images/coaching-1.jpg" alt="Dave Delaney speaking with a client during a coaching session" width="640" height="480" loading="lazy" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-md);" />
      </div>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <blockquote style="max-width: 44rem; margin: 0 auto var(--space-xl);">
      &ldquo;Dave&rsquo;s a man of many talents: a master presenter, marketer, and coach with a wide and
      varied knowledge base. He can make the driest subject fun and interesting. The thing I admire most
      about Dave is his ability to relate to everyone.&rdquo;
      <footer style="margin-top: var(--space-xs); font-size: var(--step--1); color: var(--color-text-muted);">
        &mdash; Jay Perry, ACCG, MCAC, PCC &mdash; Professional Association of ADHD Coaches (PAAC) Board of Directors
      </footer>
    </blockquote>

    <h3>Improve Your Communication, Improve Your Career</h3>
    <p>Most clients work with Dave on challenges like:</p>
    <ul style="columns: 2; column-gap: var(--space-xl);">
      <li>Clear, confident everyday communication</li>
      <li>Difficult conversations with coworkers and stakeholders</li>
      <li>Leadership presence and executive communication</li>
      <li>Staying focused and following through</li>
      <li>Improving emotional regulation and impulse management</li>
      <li>Managing overwhelm and burnout</li>
      <li>Strengthening workplace relationships</li>
      <li>Increasing reliability and trust</li>
      <li>Career clarity and next-step planning</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="hero__grid hero__grid--split">
      <div>
        <h3>1:1 Strategic Communication Coaching</h3>
        <p>Private coaching gives you dedicated, personalized support to improve how you communicate, lead, and move through your professional life.</p>
        <p>You'll get:</p>
        <ul>
          <li>Clear, empathetic listening</li>
          <li>ADHD-aware strategies to reduce overwhelm and improve follow-through</li>
          <li>Communication tools you can use immediately</li>
          <li>Leadership development based on your goals</li>
          <li>Accountability and support to stay focused</li>
          <li>Feedback, practice, and real-world application</li>
          <li>Guidance through career or identity transitions</li>
        </ul>
      </div>
      <div>
        <h3>Workplace &amp; Team Coaching</h3>
        <p>
          If your organization needs help improving communication, collaboration, or culture, Dave
          offers custom coaching and workshops for leaders and teams. These programs help your people
          communicate clearly, work together more effectively, and understand diverse thinking styles,
          including those with ADHD. <a href="/workshops">Learn more</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <div class="hero__grid hero__grid--split">
      <div>
        <img src="/images/coaching-2.jpg" alt="Dave Delaney, communication coach and keynote speaker" width="640" height="480" loading="lazy" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-md);" />
      </div>
      <div>
        <h2>About Dave Delaney</h2>
        <p>
          Hi, I'm Dave Delaney &mdash; a communication strategist, speaker, published author, and coach
          who has spent more than 20 years helping people improve the way they work together.
        </p>
        <p>
          I blend practical communication training with ADHD-aware coaching tools to help clients gain
          confidence, clarity, and momentum. My work has supported leaders and teams at Google,
          LinkedIn, FedEx, UPS, and hundreds of growing companies.
        </p>
        <p>
          I also host and produce the <strong>ADHD Wise Squirrels podcast</strong>, where I share
          ADHD-aware strategies, stories, and conversations for communication, leadership, and everyday
          life.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="eyebrow">Real testimonials, from actual humans, directly from LinkedIn.</p>
    <h2>Let's help you communicate with clarity, confidence, and purpose.</h2>
    <p class="lede">
      Free 'good fit' introduction coaching sessions are limited each month. Complete the form below to
      schedule yours now or join the waiting list when we're fully booked.
    </p>
    <div class="card-grid" style="margin-top: var(--space-lg);">
      {testimonials.map((t) => <Testimonial {...t} />)}
    </div>
    <div style="margin-top: var(--space-lg);">
      <a href="/contact" class="btn btn-primary">Let's Get Started</a>
    </div>
  </div>
</section>
