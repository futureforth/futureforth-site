---
// The Futureforth Family — homepage hub section.
// Futureforth is the parent brand over three destinations: Dave Delaney's keynote
// speaking site, the Wise Squirrels podcast site, and Futureforth's own
// coaching/workshops/consulting content (which lives directly on this site).
const brands = [
  {
    icon: '🎤',
    name: 'Dave Delaney',
    tag: 'Keynote Speaker',
    description:
      'Nashville-based keynote speaker on leadership, communication, and workplace culture.',
    href: 'https://www.davedelaney.me',
    external: true,
    cta: 'Visit davedelaney.me',
  },
  {
    icon: '🐿️',
    name: 'Wise Squirrels',
    tag: 'ADHD Podcast',
    description: 'A podcast and community for late-diagnosed adults with ADHD.',
    href: 'https://wisesquirrels.com',
    external: true,
    cta: 'Visit wisesquirrels.com',
  },
  {
    icon: '🤝',
    name: 'Futureforth',
    tag: 'Coaching, Workshops & Consulting',
    description:
      'Team workshops, 1:1 coaching, and communication consulting to help your people and your business grow.',
    href: '/workshops',
    external: false,
    cta: 'Explore our services',
  },
];
---
<section class="section brand-hub" aria-labelledby="brand-hub-heading">
  <div class="container">
    <p class="eyebrow">The Futureforth Family</p>
    <h2 id="brand-hub-heading">One brand, three ways to work with us.</h2>
    <p class="lede">
      Futureforth is the parent company behind Dave Delaney&rsquo;s keynote speaking, the Wise
      Squirrels podcast, and our own coaching, workshops, and consulting &mdash; all built on the
      same belief that communication is a superpower.
    </p>

    <div class="card-grid brand-hub__grid">
      {brands.map((brand) => (
        <a
          href={brand.href}
          class="card brand-hub__card"
          target={brand.external ? '_blank' : undefined}
          rel={brand.external ? 'noopener noreferrer' : undefined}
        >
          <span class="brand-hub__icon" aria-hidden="true">{brand.icon}</span>
          <p class="brand-hub__tag">{brand.tag}</p>
          <h3 class="brand-hub__name">
            {brand.name}
            {brand.external && <span class="brand-hub__external" aria-hidden="true">↗</span>}
          </h3>
          <p class="brand-hub__description">{brand.description}</p>
          <span class="brand-hub__cta">
            {brand.cta}
            <span aria-hidden="true">{brand.external ? ' ↗' : ' →'}</span>
            {brand.external && <span class="visually-hidden"> (opens in a new tab)</span>}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
