---
import BaseLayout from '../layouts/BaseLayout.astro';
import Testimonial from '../components/Testimonial.astro';

const testimonials = [
  { quote: "I had the pleasure of hosting a webinar where Dave Delaney served as the guest speaker, and his session was exceptional... He doesn't just talk about effective communication; he models it.", name: 'Marcha Reumel', role: 'Penn State University' },
  { quote: "I just attended Dave's Webinar on optimizing Zoom presentations and wish I'd known he was doing these long ago.", name: 'Glenna Crooks, Ph.D.' },
  { quote: 'His presentation/training session on public speaking was clear, engaging, and concise. His take-aways were tangible and applicable.', name: 'Marcy Galipeau', role: 'Pooran Law' },
  { quote: 'He held this session virtually and was able to make this a fun and interactive event (due to Covid, we could not meet in person.) I would highly recommend Dave for any of your corporate communication needs.', name: 'Carla Dodd', role: 'Silicon Ranch' },
  { quote: 'Dave Delaney is an amazing person. He has the most wonderful skills with connecting and engaging with people.', name: 'Laura Squair Heatherly', role: 'BUMC' },
  { quote: 'The presentation was engaging as much as it was informative, especially in the virtual space.', name: 'Dominique Butts', role: 'Nashville Technology Council' },
  { quote: "Dave's content is approachable and he made sure to leave our audience of 6,000+ attendees with key takeaways for how to be a Master Communicator! Bonus: he's hilarious.", name: 'Stephanie Heishman', role: "Professional BusinessWomen of California" },
  { quote: 'It was our first venture into live virtual training on a global scale and it was a huge success. Dave was engaging, funny and informative for a wide range of professionals.', name: 'Nick Cowling', role: 'Citizen Relations' },
  { quote: 'As we made the quick pivot to remote conferences due to the pandemic, Dave was right there with us shifting his planned in-person keynote to a lively and engaging opening for our online event.', name: 'Mark Marion', role: 'NTCA' },
];
---
<BaseLayout
  title="Virtual Testimonials - Futureforth"
  description="Book a virtual communication keynote presentation or workshop with Dave Delaney. All keynote presentations and workshops are available virtually, and clients love them."
  path="/virtual-testimonials"
  image="/images/virtual-testimonials-hero.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Available Virtually</p>
      <h1>Book a Virtual Communication Keynote Presentation or Workshop</h1>
      <p class="lede" style="color:#dbe3ee;">
        We believe in-person is always better for engagement and human-to-human connection, but it's not
        always possible. That's why all of our <a href="/book-dave-delaney" style="color:#fff;">keynote presentations</a>
        and <a href="/workshops" style="color:#fff;">workshops</a> are available virtually, and our
        clients love them.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn-primary">Now Booking 2026/2027</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">All testimonials are directly from Dave Delaney's LinkedIn profile.</p>
      <div class="card-grid">
        {testimonials.map((t) => <Testimonial {...t} />)}
      </div>
      <div style="margin-top: var(--space-lg);">
        <a href="/contact" class="btn btn-primary">Book Today for Your Next Online Event</a>
      </div>
    </div>
  </section>
</BaseLayout>
