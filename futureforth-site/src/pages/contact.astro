---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Us, Don't Be Shy. - Futureforth"
  description="Nobody likes pushy sales types. That's not how we roll. Let us have a quick chat with you to determine your needs to see if we're a fit."
  path="/contact"
  image="/images/og-default.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Get In Touch</p>
      <h1>Thanks for taking the first step.</h1>
      <p class="lede" style="color:#dbe3ee;">
        Not a fan of forms? Give us a shout at <a href="tel:6158231608" style="color:#fff;">615-823-1608</a>.
      </p>
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container" style="max-width: 40rem;">
      <!--
        FORM BACKEND — TODO for Dave:
        This is a static site, so the form below can't process submissions on its own.
        Two easy free options once you're ready to go live:

        1) Netlify Forms (if hosting on Netlify): add the attribute
           `data-netlify="true"` to the <form> tag below and a hidden input
           `<input type="hidden" name="form-name" value="contact" />`.
           Netlify will automatically capture submissions — no code needed.
           Docs: https://docs.netlify.com/forms/setup/

        2) Formspree (works on any host, incl. Vercel/Cloudflare Pages):
           sign up free at https://formspree.io, then change the form's
           `action` attribute below to your Formspree endpoint
           (e.g. https://formspree.io/f/yourFormId) and keep method="POST".

        Until one of those is wired up, the mailto: link below works as an
        immediate fallback so no inquiry gets lost.
      -->
      <form class="stack" method="POST" action="#" name="contact">
        <div class="form-field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-field">
          <label for="organization">Organization</label>
          <input type="text" id="organization" name="organization" />
        </div>
        <div class="form-field">
          <label for="message">How can we help?</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>

      <p class="form-note" style="margin-top: var(--space-lg);">
        This contact form needs a backend to send email (Netlify Forms or Formspree — see the
        comment in this page's source for two-minute setup instructions). Until it's connected, you
        can reach Dave directly:
        <a href="mailto:info@futureforth.com">info@futureforth.com</a> or
        <a href="tel:6158231608">615-823-1608</a>.
      </p>
    </div>
  </section>
</BaseLayout>
