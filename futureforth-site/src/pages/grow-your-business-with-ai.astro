---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGallery from '../components/ImageGallery.astro';

const galleryImages = [
  { src: '/images/ai-hero.jpg', alt: 'Dave Delaney leading an AI training session' },
  { src: '/images/workshop-5.jpg', alt: 'Small business owners learning AI workflows' },
  { src: '/images/speaking-2.jpg', alt: 'Dave Delaney speaking about AI for business' },
  { src: '/images/workshop-6.jpg', alt: 'Group discussion at an AI workshop' },
];
---
<BaseLayout
  title="Grow your business with AI. It's not too late to learn to use LLMs like ChatGPT for your business. - Futureforth"
  description="You are in great hands with a trusted by former Google Speaker, Dave Delaney. Discover what you need to know about using AI to grow your small business before your competitors do. Now booking."
  path="/grow-your-business-with-ai"
  image="/images/ai-hero.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">AI for Small Business</p>
      <h1>AI Without the Overwhelm: Practical AI Training for Small Businesses</h1>
      <p class="lede" style="color:#dbe3ee;">
        This is not an AI tools workshop. It's a confidence and clarity workshop for small businesses
        that want to use AI without feeling overwhelmed, behind, or reckless.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn-primary">Now Booking</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p>
        You don't need to become an AI expert. You need to become an <em>informed operator</em>. You know
        AI matters. You just don't know where to start.
      </p>
      <p>
        This hands-on workshop is for owners and teams who want clarity, confidence, and real-world use
        cases &mdash; not jargon or fear-based FOMO &mdash; from a former Google Speaker who gets it,
        <strong>Dave Delaney</strong>. Delaney sits at the intersection of communication, leadership, and
        technology, helping people adopt new tools without losing their values, voice, or humanity. Dave
        helps people feel calm and capable in moments of change.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="hero__grid hero__grid--split">
        <div>
          <h3>This workshop is for you if:</h3>
          <ul>
            <li>You keep hearing &ldquo;use AI or fall behind,&rdquo; but no one explains how</li>
            <li>You've tried ChatGPT once or twice and felt&hellip; underwhelmed or confused</li>
            <li>You're worried about data privacy, accuracy, or using AI the wrong way</li>
            <li>You don't want to automate everything; you want to work smarter</li>
            <li>You'd rather ask &ldquo;good questions&rdquo; than chase shiny tools</li>
          </ul>
        </div>
        <div>
          <h3>After this AI workshop, participants will:</h3>
          <ul>
            <li>Understand what AI is and is not in plain language</li>
            <li>Know where AI fits (and doesn't) in a small business</li>
            <li>Learn how to write better prompts by thinking better, not longer</li>
            <li>Identify 3&ndash;5 low-risk, high-value ways AI can save time immediately</li>
            <li>Develop an ethical, human-centered approach to using AI at work</li>
            <li>Feel confident evaluating future tools instead of feeling behind</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ImageGallery images={galleryImages} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h3>What to expect:</h3>
      <ul style="columns: 2; column-gap: var(--space-xl);">
        <li>No jargon, no coding, no pressure to perform</li>
        <li>Real examples from small businesses, not Silicon Valley</li>
        <li>Live demos you can follow along with or just observe</li>
        <li>Time for questions you've been afraid to ask</li>
        <li>A practical workbook or takeaway you can actually reuse</li>
      </ul>
    </div>
  </section>

  <section class="section section--navy text-center">
    <div class="container">
      <h2>Get clarity on AI for your business</h2>
      <p class="lede" style="margin-inline:auto;">
        You don't need to move fast. You need to move intentionally, and this AI workshop will leave you
        feeling enlightened, empowered, and entertained.
      </p>
      <a href="/contact" class="btn btn-primary">Now Booking</a>
    </div>
  </section>
</BaseLayout>
