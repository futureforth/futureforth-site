---
import BaseLayout from '../layouts/BaseLayout.astro';

const testimonials = [
  { quote: "Dave exceeded our expectations… Being a business owner, he was able to empathize with the audience and offer them real tips and advice they can use. His speech was authentic, informative and very well received by our audience.", name: 'Nicole (Belt) Cox', role: 'The UPS Store' },
  { quote: '…people love his workshop facilitation. He knows his stuff... If you have an opportunity to work together, it will be worth it.', name: 'Anastasia Kudrez', role: 'Speaker Manager and Lead Educator for Grow with Google' },
  { quote: "…Dave blew me away (as well as the audience). His engaging personality and ability to connect with his listeners make him an amazing speaker. Dave drove attendees to connect with one and other and drove further engagement of our members.", name: 'Renee McAllister', role: 'LinkedIn, Inc.' },
  { quote: "Highly recommend Dave and his ROI of Nice session with our leaders (current and emerging)! He touches on such a relevant topic with doses of humor and easy to understand techniques.", name: 'Ida Rose Metiam', role: 'Sr Manager of Quantitative Research at Asurion' },
  { quote: 'If you are looking for an engaging, educational and humorous speaker to share how to communicate better and build lasting relationships, I highly recommend Dave! Attendees loved his presentation style, his energy (& humor!) & ideas/tools that he shared.', name: 'Jamie Flynn', role: 'Executive Director at Tennessee Society of Association Executives' },
  { quote: 'He was a true professional joy to work with throughout it all. The delivery itself was fantastic, by my own opinion plus rave reviews from our audience and members.', name: 'Kristin D. Appelman', role: 'IABC' },
  { quote: "Dave's presentation to IFMA Nashville was highly informative, thought provoking (several my colleagues have started to put into practice what was learned), and most entertaining. A true professional.", name: 'JC Blakely', role: 'President, IFMA Nashville' },
  { quote: 'I would highly recommend Dave for any organization who is looking to provide effective, tangible communications tactics. He was great to work with throughout the entire process.', name: 'Ashley Taylor', role: 'AAF Madison, WI' },
  { quote: 'He was very engaging and kept everyone involved in the presentation. Definitely received great comments from many of the professionals present.', name: 'Vincent Barnes', role: 'SHRM-SCP, SPHR, Consultant, Career Coach' },
  { quote: "I booked Dave to speak at the 31st annual Professional BusinessWomen of California's conference for his Master Communicator's Secret Weapon presentation... Dave's content is approachable and he made sure to leave our audience of 6,000+ attendees with key takeaways.", name: 'Stephanie Heishman', role: 'PBWC Conference' },
  { quote: "Dave presented the Master Communicator's Secret Weapon to my agency globally during the COVID lockdown. It was our first venture into live virtual training on a global scale and it was a huge success.", name: 'Nick Cowling', role: 'Citizen Relations' },
  { quote: 'Dave did not disappoint as the keynote speaker. The room was captivated by his brilliance!!!! If you are looking for an engaging, funny and insightful speaker look no further. Dave is exceptional!', name: 'Lorneth Peters, EdD', role: 'Head of Marketing Communication, Better Business Bureau' },
  { quote: 'As we made the quick pivot to remote conferences due to the pandemic, Dave was right there with us shifting his planned in-person keynote to a lively and engaging opening for our online event.', name: 'Mark Marion', role: 'Director of Training and Development at NTCA' },
  { quote: "Dave's presentation was very well received and timely… received fresh ideas on new management techniques and approaches to employee satisfaction and retention. Dave's presentation was energetic and captivating.", name: 'Jeff Dunn', role: 'Technology Leaders of Nashville' },
  { quote: 'Dave is an incredible public speaker! Our company held an event with Dave covering the Master Communicator and the Nice Method. My team truly enjoyed the event.', name: 'Carla Dodd', role: 'Senior Manager, Office and Human Resources at Silicon Ranch Corporation' },
  { quote: '….he was awesome. We had record attendance and the membership really received some great nuggets of information to enhance their communication within business and in their personal lives.', name: 'Cory Brooks', role: 'MPI Tennessee' },
  { quote: "It was obvious from the questions and audience participation that he was connecting in a very meaningful way. Personally, I wish I had learned Dave's networking insights 10 years ago.", name: 'Brian Moyer', role: 'President, Nashville Technology Council' },
  { quote: "Dave's talk was really relatable and down-to-earth. He is humble, while confident, and he has a lot of hands-on knowledge that make his story applicable in real life situations.", name: 'Barb Braud', role: 'Senior Art Director at Lamar Advertising' },
  { quote: 'Dave was a pleasure to work with in both the lead up to our event and the delivery of his keynote session. He gave our attendees the right balance of actionable takeaways related to team communications and dynamics with the right touch of humour.', name: 'Desmond Lomas', role: 'CMP, DES, MPI' },
  { quote: 'Dave was the keynote speaker at our BBB Big Blue Bash at the Wildhorse Saloon in Nashville, and he did a phenomenal job. He presented to 200+ attendees and his information was timely, fun and thought provoking.', name: 'Melanie Thompson', role: 'Senior Regional Vice President at Better Business Bureau of Middle Tennessee & Southern Kentucky' },
  { quote: "Dave's presentation content and delivery is sincere and authentic!! We enjoyed Dave's visit to San Diego IFMA Chapter and recommend his Nice Method Presentations and Workshops.", name: 'Sarah E. Allen', role: 'IFMA, San Diego' },
  { quote: 'Dave was a keynote for our Annual Convention in June 2023. He brought energy and humor with thought provoking content. Relatable, down to earth and easy to work with.', name: 'Angela Russo', role: 'Director of Learning, New Jersey Society of CPAs' },
  { quote: "Dave's honesty, vulnerability and storytelling are unique drivers that make his presentations memorable. But in addition, he leaves his audiences with actionable steps to take to make their life better.", name: 'Sam Davidson', role: 'President and CEO of the Nashville Entrepreneur Center' },
  { quote: 'Dave provided the keynote presentation to the Pharmacy Gladiators at the Tennessee Pharmacist Association (TPA) Summer Meeting... Radical Retention is a timely and engaging perspective on the challenges facing today\'s leaders.', name: 'Jay Phipps', role: 'President of Tennessee Pharmacist Association' },
  { quote: 'Dave Delaney is a remarkable speaker who delivered an inspiring and engaging keynote speech for us at the 2024 WSTA sales and marketing seminar. Dave has a unique ability to captivate and motivate his listeners with his humor, charisma, and authenticity.', name: 'Dr. Leo Carlson, DBA' },
  { quote: 'Dave delivered the closing keynote and workshop at the 2024 LeadingAge Colorado Annual Conference and Exhibition. We were looking for someone who could end our conference on a high note with energy and humor and Dave did just that.', name: 'Sarah McVeigh, CAE', role: 'LeadingAge Colorado' },
];
---
<BaseLayout
  title="Keynote Speaker, Dave Delaney Reviews - Futureforth"
  description="Nice things our clients say about keynote speaker Dave Delaney — testimonials from Google, LinkedIn, FedEx, UPS, SHRM, IABC, and dozens more organizations."
  path="/presentation-testimonials-1"
  image="/images/testimonials-hero.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Reviews</p>
      <h1>Nice things our clients say&hellip;</h1>
      <p class="lede" style="color:#dbe3ee;">We thank them for their kind words!</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {testimonials.map((t) => (
          <div class="testimonial">
            <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
            <cite>{t.name}{t.role && `, ${t.role}`}</cite>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: var(--space-xl);">
        <a href="/contact" class="btn btn-primary">Let's Chat</a>
      </div>
    </div>
  </section>
</BaseLayout>
