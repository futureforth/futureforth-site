---
import BaseLayout from '../layouts/BaseLayout.astro';
import Testimonial from '../components/Testimonial.astro';

const testimonials = [
  { quote: "People love his workshop facilitation. He knows his stuff... If you have an opportunity to work together, it will be worth it.", name: 'Anastasia Kudrez', role: 'Lead Educator for Grow with Google' },
  { quote: 'Dave is the Real Deal! His approach and knowledge made the time and investment pay off immediately. Yes, we give Dave as many "Thumbs Up" as we possibly can.', name: 'Ginger Hardage', role: 'Former SVP of Culture & Communications at Southwest Airlines' },
  { quote: 'Dave’s style is confident, funny and direct...one of the best five hours I have spent professionally.', name: 'Katie Owens', role: 'Vice President, HealthStream Engagement Institute' },
  { quote: 'My team truly enjoyed the event and have taken the tools provided to be able to improve both communication internally and externally. I would highly recommend Dave for any of your corporate communication needs.', name: 'Carla Dodd', role: 'Silicon Ranch' },
  { quote: "\"... really relatable and down-to-earth. He is humble, while confident, and he has a lot of hands-on knowledge... He really knows what he's talking about.\"", name: 'Barb Braud', role: 'Lamar Advertising' },
  { quote: 'Dave recently provided speaker training for our team… His training was not only informative, we had tons of fun and laughed a lot! We each learned valuable take-aways that we plan to apply to our future presentations.', name: 'Melanie Jore', role: 'Vice President of Member Relations at NTCA' },
];
---
<BaseLayout
  title="Futureforth - Professional Development &amp; Leadership Training."
  description="Futureforth is a leadership and professional development training firm serving fast-growing technology companies that seek ways to increase employee retention, strengthen company culture, retain clients, and improve communication."
  path="/workshops"
  image="/images/workshop-2.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Communication Workshops</p>
      <h1>Your Company Can&rsquo;t Afford Poor Communication</h1>
      <p class="lede" style="color:#dbe3ee;">
        Bring your team together to learn, laugh, and connect like never before, virtually or in person.
        Increase employee retention, strengthen company culture, and improve communication with
        Futureforth Nice Method workshops for your next off-site, company retreat, or executive
        leadership team event.
      </p>
      <div class="hero__actions">
        <a href="/contact#contact" class="btn btn-primary">Inquire Today</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p>
        The costs of recruiting and training new employees keep increasing; it slows your business down
        whenever you need to replace someone, and turnover contagion can quickly lead to a mass exodus.
        Stop throwing money and time at the problem, hoping no one will notice if you move fast enough.
      </p>
      <p>
        On the flip side, if retention is going well, at what point do you think complacency could occur
        or a communication breakdown? Is it already?
      </p>
      <p>
        Our elated clients come away with a clear understanding of their strengths, reimagined listening
        abilities, improved presentation performance skills, aligned company culture values, and a more
        humanistic brand.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Workshops to Improve Communication Skills</p>
      <h2>NEW in 2026: Grow Your Business with AI &amp; Improve with Improv</h2>

      <div class="card-grid" style="margin-top: var(--space-lg);">
        <div class="card">
          <img src="/images/workshop-2.jpg" alt="Nice Method Secret Weapon workshop in progress" width="400" height="280" loading="lazy" style="border-radius: var(--radius-sm); margin-bottom: var(--space-sm);" />
          <h3>Nice Method &ldquo;Secret Weapon&rdquo; Workshop</h3>
          <p>
            Audiences love Dave Delaney's <a href="/nice-method-presentations">Master Communicator's Secret Weapon keynote presentation</a>.
            Why not add a workshop to your conference, convention, or company retreat? Get ready for a
            fun-filled, highly interactive workshop that will have your people thinking quickly on their
            feet while interacting, laughing, and learning along with their fellow participants. Earn
            trust, build relationships, become more creative, embrace spontaneity, use body language,
            lead with acceptance, actively listen, and improve your communication skills as you apply
            the 'secret weapon' in this engaging workshop.
          </p>
        </div>
        <div class="card">
          <img src="/images/workshop-3.jpg" alt="Storytelling and presentation planning workshop" width="400" height="280" loading="lazy" style="border-radius: var(--radius-sm); margin-bottom: var(--space-sm);" />
          <h3>Nice Method Storytelling &amp; Presentation Planning</h3>
          <p>
            Delve into the history and power of storytelling and its vital role in human communication.
            Drawing inspiration from improv and standup comedy, learn techniques to think on your feet
            and conquer fear. Explore story arches as building blocks for captivating narratives.
          </p>
          <p>
            Unlock audience engagement methods, both tried-and-true and innovative. Master the S.H.O.T.
            approach for effective presentation outlines. Loosen up with 4 &amp; 8 breathing and limb
            exercises, boosting your presence and confidence.
          </p>
        </div>
        <div class="card">
          <img src="/images/workshop-4.jpg" alt="Nice Method conflict resolution and mediation workshop" width="400" height="280" loading="lazy" style="border-radius: var(--radius-sm); margin-bottom: var(--space-sm);" />
          <h3>Nice Method for Conflict Resolution &amp; Mediation</h3>
          <p>
            This team-building and conflict-resolution workshop is designed to help participants develop
            essential communication and mediation skills for a harmonious workplace. Through interactive
            sessions, attendees will learn techniques like active listening and the "NICE Method" for
            addressing and resolving conflicts effectively. Mindfulness exercises and empathy practices
            will guide participants in maintaining calm and control during high-stress situations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="hero__grid hero__grid--split">
        <div>
          <img src="/images/workshop-5.jpg" alt="Leveraging AI for Small Business Growth workshop session" width="640" height="480" loading="lazy" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-md);" />
        </div>
        <div>
          <h2>Leveraging AI for Small Business Growth: Content Creation &amp; Strategy</h2>
          <p>
            Dave Delaney's workshop, <a href="/grow-your-business-with-ai">Leveraging AI for Small Business Growth: Content Creation &amp; Strategy</a>,
            offers practical training for small business owners and marketing professionals. The session
            focuses on how Artificial Intelligence can revolutionize content creation and marketing
            strategies, enabling businesses to compete more effectively in today's digital landscape.
          </p>
          <p>
            The workshop also includes real-world case studies showcasing small businesses that have
            achieved significant growth by integrating AI into their workflows, led by digital marketing
            veteran and communication expert Dave Delaney.
          </p>
          <a href="/contact" class="btn btn-primary">Contact Us Today to Learn More</a>
          <p style="margin-top: var(--space-sm); font-style: italic; color: var(--color-text-muted);">
            Ask us about our train-the-trainer presentation skills workshops.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Featured</p>
      <h2>What clients say</h2>
      <div class="card-grid">
        {testimonials.map((t) => <Testimonial {...t} />)}
      </div>
      <div style="margin-top: var(--space-lg);">
        <a href="/contact" class="btn btn-primary">Check Availability</a>
      </div>
    </div>
  </section>
</BaseLayout>
