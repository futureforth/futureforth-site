---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGallery from '../components/ImageGallery.astro';
import TrustLogos from '../components/TrustLogos.astro';
import BrandHub from '../components/BrandHub.astro';
import { organizationSchema, daveDelaneyPersonSchema } from '../data/schema.js';

const speakingImages = [
  { src: '/images/speaking-1.jpg', alt: 'Dave Delaney delivering a keynote presentation on stage' },
  { src: '/images/speaking-2.jpg', alt: 'Dave Delaney speaking to a corporate audience' },
  { src: '/images/speaking-3.jpg', alt: 'Dave Delaney presenting with a large screen behind him' },
  { src: '/images/speaking-4.jpg', alt: 'Audience engaged during a Dave Delaney keynote' },
  { src: '/images/speaking-5.jpg', alt: 'Dave Delaney keynote speaker on stage with microphone' },
  { src: '/images/speaking-6.jpg', alt: 'Dave Delaney delivering his TEDx talk' },
  { src: '/images/speaking-7.jpg', alt: 'Dave Delaney leading a Nice Method presentation' },
  { src: '/images/speaking-8.jpg', alt: 'Dave Delaney at a storytelling and presentation workshop' },
];

const workshopImages = [
  { src: '/images/workshop-1.jpg', alt: 'Corporate improv training session in Nashville' },
  { src: '/images/workshop-2.jpg', alt: 'Communication Mastery Workshop participants role-playing' },
  { src: '/images/workshop-3.jpg', alt: 'Team workshop activity led by Dave Delaney' },
  { src: '/images/workshop-4.jpg', alt: 'Workshop attendees practicing active listening exercises' },
  { src: '/images/workshop-5.jpg', alt: 'Grow Your Business with AI workshop training session' },
  { src: '/images/workshop-6.jpg', alt: 'Group photo from a Futureforth team workshop' },
];
---
<BaseLayout
  title="Futureforth - Communication Strategy | Keynote Speaker | Workshop Facilitation | Coaching &amp; Consulting."
  description="Opportunities slip away when communication is unclear. Keynote speaker and communication expert Dave Delaney will teach your team how to improve communication and coach leaders on becoming master communicators."
  path="/"
  image="/images/og-default.jpg"
  jsonLd={[organizationSchema, daveDelaneyPersonSchema]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Keynote Speaker &amp; Communication Strategist</p>
      <h1>Communication isn&rsquo;t a soft skill.</h1>
      <p class="lede" style="color:#dbe3ee; font-size: var(--step-3); font-family: var(--font-display); font-weight: 700;">
        It&rsquo;s a superpower!
      </p>
      <p class="lede" style="color:#dbe3ee;">
        Acclaimed presentations and coaching that transform how you communicate.
      </p>
      <blockquote style="background: rgba(255,255,255,0.08); border-color: var(--color-accent); color: #fff; margin-top: var(--space-md); max-width: 42rem;">
        &ldquo;Communication is the most important skill any leader can possess.&rdquo;
        <footer style="margin-top: var(--space-xs); font-size: var(--step--1); opacity: 0.8;">&mdash; Richard Branson, Founder at Virgin Group</footer>
      </blockquote>
      <div class="hero__actions">
        <a href="/book-dave-delaney" class="btn btn-primary">Keynote Speaker, Dave Delaney</a>
      </div>
    </div>
  </section>

  <BrandHub />

  <section class="section">
    <div class="container">
      <p class="eyebrow">Keynote Presentations</p>
      <h2>Enlighten, empower, and entertain your audience.</h2>
      <p class="lede">
        Dave Delaney's acclaimed expert keynote presentations about communication will enlighten your
        group with new and refined communication skills, empower your people to apply what they learn
        immediately, and entertain them with inspiring case studies and laugh-out-loud stories.
      </p>
      <ImageGallery images={speakingImages} />
      <div style="margin-top: var(--space-lg);">
        <a href="/communication-presentations" class="btn btn-primary">Inquire here</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <p class="eyebrow">Team Workshops</p>
      <h2>Highly interactive workshops your team will remember.</h2>
      <p class="lede">
        Highly interactive and engaging workshops that incorporate role-playing with storytelling,
        presentation skills with sales, and active listening with overcoming a fear of failure. Learn
        how to present your ideas with confidence in person or virtually to your team, prospects,
        clients, investors, and community.
      </p>
      <ImageGallery images={workshopImages} />
      <div style="margin-top: var(--space-lg);">
        <a href="/workshops" class="btn btn-primary">Now booking</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="hero__grid hero__grid--split">
        <div>
          <p class="eyebrow">Professional Coaching</p>
          <h2>Grow your business and your career.</h2>
          <p class="lede">
            Discover how to grow your business, develop professional relationships, improve
            communication skills, and incorporate modern and traditional marketing and digital
            strategies to help you reach your goals and succeed as a leader. One-on-one coaching
            availability is limited. Your first session is complimentary.
          </p>
          <a href="/personal-coaching" class="btn btn-primary">Schedule a &ldquo;Good Fit&rdquo; Session</a>
        </div>
        <div>
          <img src="/images/coaching-1.jpg" alt="Dave Delaney leading a 1:1 coaching conversation" width="640" height="480" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--navy text-center">
    <div class="container">
      <h2>Ready to talk?</h2>
      <a href="/contact" class="btn btn-primary">Contact Us</a>
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <p class="eyebrow">Trusted By</p>
      <TrustLogos />
      <blockquote style="max-width: 40rem; margin: var(--space-xl) auto 0;">
        &ldquo;Communication isn&rsquo;t a soft skill. It&rsquo;s a superpower.&rdquo;
        <footer style="margin-top: var(--space-xs); font-size: var(--step--1); color: var(--color-text-muted);">&mdash; Dave Delaney, powered by Futureforth</footer>
      </blockquote>
      <p style="margin-top: var(--space-md);">
        <a href="/presentation-testimonials-1">Logos are lovely, but what did they say?</a>
      </p>
    </div>
  </section>
</BaseLayout>
