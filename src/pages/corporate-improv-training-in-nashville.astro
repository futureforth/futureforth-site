---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageGallery from '../components/ImageGallery.astro';
import Testimonial from '../components/Testimonial.astro';

const galleryImages = [
  { src: '/images/workshop-1.jpg', alt: 'Corporate improv training exercise in Nashville' },
  { src: '/images/workshop-2.jpg', alt: 'Communication Mastery Workshop group activity' },
  { src: '/images/workshop-3.jpg', alt: 'Improv training participants practicing together' },
  { src: '/images/workshop-4.jpg', alt: 'Team improv exercise focused on active listening' },
  { src: '/images/speaking-7.jpg', alt: 'Dave Delaney leading an improv-based workshop' },
  { src: '/images/workshop-6.jpg', alt: 'Group photo after a corporate improv training session' },
];

const testimonials = [
  { quote: 'People love his workshop facilitation. He knows his stuff... If you have an opportunity to work together, it will be worth it.', name: 'Anastasia Kudrez', role: 'Lead Educator for Grow with Google' },
  { quote: 'Dave is the Real Deal! His approach and knowledge made the time and investment pay off immediately.', name: 'Ginger Hardage', role: 'Former SVP of Culture & Communications at Southwest Airlines' },
  { quote: 'My team truly enjoyed the event and have taken the tools provided to be able to improve both communication internally and externally.', name: 'Carla Dodd', role: 'Silicon Ranch' },
];
---
<BaseLayout
  title="Corporate Improv Training in Nashville - Futureforth"
  description="Join communication expert, Dave Delaney, Second City graduate, seasoned improv performer and trainer for a comprehensive workshop. Trusted by Google, FedEx, UPS, and many more brands."
  path="/corporate-improv-training-in-nashville"
  image="/images/improv-hero.jpg"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow" style="color: var(--color-accent);">Corporate Improv Training</p>
      <h1>Improve With Improv</h1>
      <p class="lede" style="color:#dbe3ee;">
        Looking for an improv trainer in Nashville for business? You found him.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="btn btn-primary">Book Today</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p>
        The cat's out of the bag. For over a decade, <a href="/about#dave">Dave Delaney</a> has been
        delivering his acclaimed keynote presentation, The Master Communicator's Secret Weapon. He's
        revealed to thousands of people that his secret weapon is <em>improv</em>, and you can take its
        core concepts and apply them to how you communicate and show up for your colleagues, teams,
        customers, and prospects, and even closer to home with your families and friends.
      </p>
      <p>
        Corporate improv training can stir an array of different emotions, from fear and skepticism to
        excitement and wonder. Who teaches improv to teams matters. You need an improv teacher who has
        earned empathy through their own experiences working for both smaller start-ups and large
        corporations, and who is trusted by Google, FedEx, UPS, and many more brands.
      </p>
      <p>
        Not only is Dave Delaney a graduate from Second City and a seasoned improv performer and
        facilitator, but he's also an acclaimed keynote speaker and trainer, who has been in your shoes
        &mdash; from corporate tower cubicles to home offices &mdash; online and offline.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2>Interested in your group discovering how to&hellip;</h2>
      <ImageGallery images={galleryImages} />
      <ul style="margin-top: var(--space-lg); columns: 2; column-gap: var(--space-xl);">
        <li>Lead with acceptance to improve leadership skills</li>
        <li>Use active listening to empower your people, clients, and prospects</li>
        <li>Overcome the fear of failure to innovate and collaborate</li>
        <li>Decipher body language to read a room and measure a moment</li>
        <li>Improve relationships among colleagues to build relationships, attract, and retain top talent</li>
        <li>Think fast on your feet while having fun together</li>
        <li>Improve your meetings, tradeshows, and presentation outcomes</li>
      </ul>
      <div style="margin-top: var(--space-lg);">
        <a href="/contact" class="btn btn-primary">Inquire Today</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Featured</p>
      <h2>What clients say</h2>
      <div class="card-grid">
        {testimonials.map((t) => <Testimonial {...t} />)}
      </div>
      <div style="margin-top: var(--space-lg);">
        <a href="/contact" class="btn btn-primary">Check Availability</a>
      </div>
    </div>
  </section>
</BaseLayout>
